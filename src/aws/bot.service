[Unit]
Description=WebullTradeAI trading bot
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=ec2-user
WorkingDirectory=/home/ec2-user/WebullTradeAI

# Load environment variables from .env
EnvironmentFile=/home/ec2-user/WebullTradeAI/.env

# Restore any missing state files from S3 before trading
ExecStartPre=/home/ec2-user/WebullTradeAI/.venv/bin/python -c \
    "import sys; sys.path.insert(0, 'src/core'); from dashboard_logger import restore_state_from_s3; restore_state_from_s3()"

# Main bot entry point — replace with your actual run script
ExecStart=/home/ec2-user/WebullTradeAI/.venv/bin/python src/aws/main.py

# Restart on failure (crash recovery)
Restart=on-failure
RestartSec=30
StartLimitIntervalSec=300
StartLimitBurst=3

# Log to systemd journal — view with: journalctl -u bot.service -f
StandardOutput=journal
StandardError=journal
SyslogIdentifier=webull-bot

# On weekends (UTC Sat=6 or Sun=7), retrain may be running — don't shut down.
# On weekdays, shut down after trading to avoid idle EC2 costs.
ExecStopPost=/bin/bash -c 'day=$(date +%%u); if [ "$day" -ge 6 ]; then exit 0; fi; sudo /sbin/shutdown -h now'

[Install]
WantedBy=multi-user.target
